    "fastify": "^4.26.2"
  },
  "devDependencies": {
    "@tanstack/react-query": "^5.28.4",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^20.11.28",
    "@types/react": "^18.2.66",
    "@types/react-dom": "^18.2.22",
    "@vitejs/plugin-react": "^4.2.1",
    "autoprefixer": "^10.4.18",
    "axios": "^1.6.8",
    "concurrently": "^8.2.2",
    "postcss": "^8.4.35",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^6.22.3",
    "tailwindcss": "^3.4.1",
